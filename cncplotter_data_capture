def read_cnc_serial():
    global cnc_buffer, last_seen_x_mm, last_seen_y_mm, last_seen_z_mm, last_status_line

    try:
        n = cnc_ser.in_waiting
    except Exception:
        return

    if n <= 0:
        return

    try:
        chunk = cnc_ser.read(n).decode(errors="ignore")
    except Exception:
        return

    if not chunk:
        return

    cnc_buffer += chunk.replace("\r", "")
    lines = cnc_buffer.split("\n")
    cnc_buffer = lines[-1]
    complete_lines = lines[:-1]

    if len(complete_lines) > MAX_LINES_PER_UPDATE:
        complete_lines = complete_lines[-MAX_LINES_PER_UPDATE:]

    for line in complete_lines:
        line = line.strip()
        if not line:
            continue

        last_cnc_line_label.setText(f"Last CNC line: {line[:140]}")
        last_status_line = line

        pos = parse_position_line(line)
        if pos is not None:
            coord_kind, x, y, z = pos
            last_seen_x_mm = x
            last_seen_y_mm = y
            last_seen_z_mm = z

            if session_origin_x_mm is not None and session_origin_y_mm is not None:
                local_x = x - session_origin_x_mm
                local_y = y - session_origin_y_mm
                actual_pos_label.setText(
                    f"Reported position ({coord_kind}): X={x:.3f} mm, Y={y:.3f} mm, Z={z:.3f} mm | "
                    f"local X={local_x:+.3f} mm, Y={local_y:+.3f} mm"
                )
            else:
                actual_pos_label.setText(
                    f"Reported position ({coord_kind}): X={x:.3f} mm, Y={y:.3f} mm, Z={z:.3f} mm"
                )

        elif line.lower().startswith("error"):
            status_label.setText(f"Status: CNC {line}")
        elif line.lower().startswith("alarm"):
            status_label.setText(f"Status: CNC {line}")


def read_sensor_serial():
    global sensor_buffer, baseline_pa0, baseline_pa5, baseline_pa6, sample_counter

    try:
        n = sensor_ser.in_waiting
    except Exception:
        return False

    if n <= 0:
        return False

    try:
        chunk = sensor_ser.read(n).decode(errors="ignore")
    except Exception:
        return False

    if not chunk:
        return False

    sensor_buffer += chunk.replace("\r", "")
    lines = sensor_buffer.split("\n")
    sensor_buffer = lines[-1]
    complete_lines = lines[:-1]

    if len(complete_lines) > MAX_LINES_PER_UPDATE:
        complete_lines = complete_lines[-MAX_LINES_PER_UPDATE:]

    updated_plot = False

    for line in complete_lines:
        line = line.strip()
        if not line:
            continue

        last_sensor_line_label.setText(f"Last sensor line: {line[:140]}")

        parsed = parse_adc_line(line)
        if parsed is None:
            continue

        raw_pa0, raw_pa5, raw_pa6 = parsed

        if baseline_pa0 is None:
            baseline_pa0 = raw_pa0
            baseline_pa5 = raw_pa5
            baseline_pa6 = raw_pa6
            baseline_label.setText(
                f"Baseline: PA0={baseline_pa0}, PA5={baseline_pa5}, PA6={baseline_pa6}"
            )
            instruction_label.setText("Baseline ready. Press Start Calibration.")
            status_label.setText("Status: baseline ready")
            print(f"Baseline set: PA0={baseline_pa0}, PA5={baseline_pa5}, PA6={baseline_pa6}")
            continue

        delta_pa0 = raw_pa0 - baseline_pa0
        delta_pa5 = raw_pa5 - baseline_pa5
        delta_pa6 = raw_pa6 - baseline_pa6

        y_pa0.append(delta_pa0)
        y_pa5.append(delta_pa5)
        y_pa6.append(delta_pa6)

        maybe_expand_ylim(delta_pa0, delta_pa5, delta_pa6)
        append_training_row(raw_pa0, raw_pa5, raw_pa6, delta_pa0, delta_pa5, delta_pa6)

        sample_counter += 1
        updated_plot = True

    return updated_plot


