# ============================================================
# SERIAL SETTINGS
# ============================================================
CNC_PORT = "COM26"          # Genmitsu / Grbl controller
CNC_BAUD = 115200

SENSOR_PORT = "COM11"       # your sensor MCU
SENSOR_BAUD = 9600

SERIAL_TIMEOUT = 0

# ============================================================
# CALIBRATION SETTINGS
# ============================================================
# The CNC position when you press Start Calibration becomes the local test
# origin (0, 0). The scan below is generated in local coordinates around
# that origin, while motion commands sent to Grbl remain absolute.
LOCAL_X_MIN_MM = -8.0
LOCAL_X_MAX_MM =  8.0
LOCAL_X_STEP_MM = 0.5

LOCAL_Y_MIN_MM = -10.0
LOCAL_Y_MAX_MM =  10.0
LOCAL_Y_STEP_MM = 0.5

REPEATS_PER_POINT = 3

SETTLE_SECONDS = 0.05
SAMPLES_PER_POINT = 10
REBASELINE_EACH_REPEAT = True

USE_POSITION_CONFIRM     = True
POS_CONFIRM_TOLERANCE_MM = 0.05
POS_CONFIRM_TIMEOUT_SEC  = 0.05
POS_P_INTERVAL_SEC       = 0.15

CAPTURE_TIMEOUT_SEC      = 8.0
C_REQUEST_INTERVAL_SEC   = 0.05

HOME_X_MM = 0
HOME_Y_MM = 0

OUTPUT_CSV_BASE = "sensor_position_calibration"
TIMESTAMP_CSV   = True

# ============================================================
# CNC / GRBL SETTINGS
# ============================================================
MOVE_FEED_MM_MIN = 2000.0
MOVE_CMD = "G1"
AUTO_UNLOCK = True
AUTO_SET_MM_ABS = True

USE_Z_LIFT = False
SAFE_Z_MM = 5.0

# ============================================================
# PLOT SETTINGS
# ============================================================
MAX_POINTS = 500
MAX_LINES_PER_UPDATE = 80
DEFAULT_Y_MIN = -450
DEFAULT_Y_MAX = 150
Y_MARGIN = 20
SMOOTH_N = 5

# ============================================================
# PARSERS
# ============================================================
ADC_PATTERN = re.compile(
    r"PA0:\s*(-?\d+)\s*,\s*PA5:\s*(-?\d+)\s*,\s*PA6:\s*(-?\d+)",
    re.IGNORECASE,
)

GRBL_MPOS_PATTERN = re.compile(
    r"<[^>]*\|MPos:\s*(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)",
    re.IGNORECASE,
)
GRBL_WPOS_PATTERN = re.compile(
    r"<[^>]*\|WPos:\s*(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)",
    re.IGNORECASE,
)

# ============================================================
# OPEN SERIAL PORTS
# ============================================================
try:
    cnc_ser = serial.Serial(CNC_PORT, CNC_BAUD, timeout=SERIAL_TIMEOUT)
    time.sleep(2.0)
    cnc_ser.reset_input_buffer()
    cnc_ser.reset_output_buffer()
except serial.SerialException as e:
    print(f"Could not open CNC serial port {CNC_PORT}: {e}")
    sys.exit(1)

try:
    sensor_ser = serial.Serial(SENSOR_PORT, SENSOR_BAUD, timeout=SERIAL_TIMEOUT)
    time.sleep(2.0)
    sensor_ser.reset_input_buffer()
except serial.SerialException as e:
    print(f"Could not open sensor serial port {SENSOR_PORT}: {e}")
    sys.exit(1)

