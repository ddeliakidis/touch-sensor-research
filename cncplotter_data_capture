# ============================================================
# HELPERS
# ============================================================
def moving_avg(values, n):
    vals = list(values)
    if not vals:
        return 0.0
    if len(vals) < n:
        return sum(vals) / len(vals)
    return sum(vals[-n:]) / n


def frange_inclusive(min_mm, max_mm, step_mm):
    if step_mm <= 0:
        raise ValueError("step_mm must be positive")
    if max_mm < min_mm:
        raise ValueError("max_mm must be >= min_mm")

    vals = []
    x = float(min_mm)
    while x <= max_mm + 1e-9:
        vals.append(round(x, 4))
        x += step_mm
    return vals


def parse_adc_line(line):
    match = ADC_PATTERN.search(line)
    if not match:
        return None
    return tuple(int(x) for x in match.groups())


def parse_position_line(line):
    m = GRBL_WPOS_PATTERN.search(line)
    if m:
        return "WPos", float(m.group(1)), float(m.group(2)), float(m.group(3))

    m = GRBL_MPOS_PATTERN.search(line)
    if m:
        return "MPos", float(m.group(1)), float(m.group(2)), float(m.group(3))

    return None


def send_cnc_cmd(cmd):
    try:
        msg = cmd + "\n"
        print("CNC TX:", repr(msg))
        cnc_ser.write(msg.encode("utf-8"))
        cnc_ser.flush()
        return True
    except Exception as e:
        status_label.setText(f"Status: CNC write failed: {e}")
        print("CNC TX ERROR:", e)
        return False


def send_sensor_cmd(cmd):
    try:
        msg = cmd + "\r\n"
        print("SENSOR TX:", repr(msg))
        sensor_ser.write(msg.encode("utf-8"))
        sensor_ser.flush()
        return True
    except Exception as e:
        status_label.setText(f"Status: sensor write failed: {e}")
        print("SENSOR TX ERROR:", e)
        return False


def wake_and_init_grbl():
    try:
        cnc_ser.write(b"\r\n\r\n")
        cnc_ser.flush()
        time.sleep(2.0)
        cnc_ser.reset_input_buffer()
    except Exception as e:
        print("GRBL wake failed:", e)

    if AUTO_UNLOCK:
        send_cnc_cmd("$X")
        time.sleep(0.2)

    if AUTO_SET_MM_ABS:
        send_cnc_cmd("G21")  # mm
        send_cnc_cmd("G90")  # absolute coordinates
        send_cnc_cmd("G94")  # feed per minute
        time.sleep(0.1)

    send_cnc_cmd("?")


def maybe_expand_ylim(v0, v5, v6):
    ymin, ymax = plot.getViewBox().viewRange()[1]
    low = min(v0, v5, v6)
    high = max(v0, v5, v6)

    new_ymin = ymin
    new_ymax = ymax

    if low < ymin:
        new_ymin = min(DEFAULT_Y_MIN, low - Y_MARGIN)
    if high > ymax:
        new_ymax = max(DEFAULT_Y_MAX, high + Y_MARGIN)

    if new_ymin != ymin or new_ymax != ymax:
        plot.setYRange(new_ymin, new_ymax, padding=0)


def reset_live_state(clear_baseline=True):
    global baseline_pa0, baseline_pa5, baseline_pa6
    global cnc_buffer, sensor_buffer, sample_counter
    global point_pa0_samples, point_pa5_samples, point_pa6_samples

    if clear_baseline:
        baseline_pa0 = None
        baseline_pa5 = None
        baseline_pa6 = None

    cnc_buffer = ""
    sensor_buffer = ""
    sample_counter = 0

    point_pa0_samples = []
    point_pa5_samples = []
    point_pa6_samples = []

    y_pa0.clear()
    y_pa5.clear()
    y_pa6.clear()

    curve_pa0.setData([], [])
    curve_pa5.setData([], [])
    curve_pa6.setData([], [])
    plot.setYRange(DEFAULT_Y_MIN, DEFAULT_Y_MAX, padding=0)
    plot.setXRange(0, MAX_POINTS - 1, padding=0)

    try:
        cnc_ser.reset_input_buffer()
    except Exception:
        pass

    try:
        sensor_ser.reset_input_buffer()
    except Exception:
        pass


def build_session_sequence():
    xs_local = frange_inclusive(LOCAL_X_MIN_MM, LOCAL_X_MAX_MM, LOCAL_X_STEP_MM)
    ys_local = frange_inclusive(LOCAL_Y_MIN_MM, LOCAL_Y_MAX_MM, LOCAL_Y_STEP_MM)

    seq = []
    for repeat_num in range(1, REPEATS_PER_POINT + 1):
        for row_idx, local_y in enumerate(ys_local):
            x_order = xs_local if row_idx % 2 == 0 else list(reversed(xs_local))
            for local_x in x_order:
                seq.append((repeat_num, local_x, local_y))
    return seq


def _make_output_path():
    if TIMESTAMP_CSV:
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        return f"{OUTPUT_CSV_BASE}_{ts}.csv"
    return f"{OUTPUT_CSV_BASE}.csv"


def save_rows_to_csv():
    if not rows:
        status_label.setText("Status: no data to save")
        return

    fieldnames = [
        "session_time_s",
        "point_time_s",
        "point_index",
        "repeat",
        "origin_x_mm",
        "origin_y_mm",
        "origin_z_mm",
        "cmd_x_mm",
        "cmd_y_mm",
        "cmd_abs_x_mm",
        "cmd_abs_y_mm",
        "raw_pa0",
        "raw_pa5",
        "raw_pa6",
        "delta_pa0",
        "delta_pa5",
        "delta_pa6",
        "smooth_pa0",
        "smooth_pa5",
        "smooth_pa6",
    ]

    path = _make_output_path()
    with open(path, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(rows)

    status_label.setText(f"Status: saved {len(rows)} rows to {path}")
    print(f"Saved {len(rows)} rows to {path}")


def move_to_xy(x_mm, y_mm):
    if USE_Z_LIFT:
        if not send_cnc_cmd("G90"):
            return False
        if not send_cnc_cmd(f"G0 Z{SAFE_Z_MM:.3f}"):
            return False
        time.sleep(0.05)

    if not send_cnc_cmd("G90"):
        return False

    cmd = f"{MOVE_CMD} X{x_mm:.3f} Y{y_mm:.3f} F{MOVE_FEED_MM_MIN:.3f}"
    return send_cnc_cmd(cmd)


def advance_to_next_point():
    global session_index, session_state, state_start_time
    global current_repeat, current_local_x_mm, current_local_y_mm
    global current_abs_x_mm, current_abs_y_mm, samples_this_point
    global point_pa0_samples, point_pa5_samples, point_pa6_samples

    session_index += 1

    if session_index >= len(session_sequence):
        session_state = "DONE"
        state_start_time = time.monotonic()
        current_repeat = None
        current_local_x_mm = None
        current_local_y_mm = None
        current_abs_x_mm = None
        current_abs_y_mm = None
        samples_this_point = 0

        prompt_label.setText("DONE")
        instruction_label.setText("Calibration finished")
        countdown_label.setText("Capture: done")
        progress_label.setText(f"Completed {len(rows)} rows")
        point_label.setText("Target point: -")
        samples_label.setText("Samples at point: -")
        save_rows_to_csv()
        return

    new_repeat, new_local_x, new_local_y = session_sequence[session_index]

    if REBASELINE_EACH_REPEAT and current_repeat is not None and new_repeat != current_repeat:
        reset_live_state(clear_baseline=True)
        baseline_label.setText("Baseline: re-zeroing for new repeat…")
        status_label.setText(f"Status: rebaselining for repeat {new_repeat}")
        print(f"Repeat boundary {current_repeat}→{new_repeat}: baseline reset")

    current_repeat = new_repeat
    current_local_x_mm = new_local_x
    current_local_y_mm = new_local_y
    current_abs_x_mm = session_origin_x_mm + current_local_x_mm
    current_abs_y_mm = session_origin_y_mm + current_local_y_mm
    samples_this_point = 0

    point_pa0_samples = []
    point_pa5_samples = []
    point_pa6_samples = []

    ok = move_to_xy(current_abs_x_mm, current_abs_y_mm)
    if not ok:
        return

    session_state = "SETTLE"
    state_start_time = time.monotonic()

    prompt_label.setText(
        f"{MOVE_CMD} X{current_abs_x_mm:.3f} Y{current_abs_y_mm:.3f} "
        f"(local X={current_local_x_mm:+.3f}, Y={current_local_y_mm:+.3f})"
    )
    instruction_label.setText("Moving CNC to calibration point")
    countdown_label.setText(f"Prepare: {SETTLE_SECONDS:0.2f}s")
    progress_label.setText(
        f"Point {session_index + 1}/{len(session_sequence)} | Repeat {current_repeat}/{REPEATS_PER_POINT}"
    )
    point_label.setText(
        f"Target point: local X={current_local_x_mm:+.3f} mm, Y={current_local_y_mm:+.3f} mm | "
        f"abs X={current_abs_x_mm:.3f} mm, Y={current_abs_y_mm:.3f} mm"
    )
    samples_label.setText(f"Samples at point: 0/{SAMPLES_PER_POINT}")
    status_label.setText("Status: moving CNC")


def start_collection():
    global rows, session_sequence, session_index
    global session_start_time, session_state, state_start_time
    global session_origin_x_mm, session_origin_y_mm, session_origin_z_mm

    if baseline_pa0 is None:
        status_label.setText("Status: waiting for first valid sensor sample")
        return

    # Assume work zero is already set where the user wants it (via the Zero
    # XYZ Here button, or externally). The scan grid is driven in local
    # coordinates, which GRBL interprets against the current work zero.
    session_origin_x_mm = 0.0
    session_origin_y_mm = 0.0
    session_origin_z_mm = last_seen_z_mm if last_seen_z_mm is not None else 0.0

    origin_label.setText(
        "Session origin: using current CNC work zero — "
        "press 'Zero XYZ Here' first if you haven't set it"
    )

    rows = []
    session_sequence = build_session_sequence()
    session_index = -1
    session_start_time = time.monotonic()
    session_state = "IDLE"
    state_start_time = None

    status_label.setText(
        f"Status: calibration started from local zero at "
        f"X={session_origin_x_mm:.3f}, Y={session_origin_y_mm:.3f}"
    )
    advance_to_next_point()


def stop_collection():
    global session_state
    session_state = "IDLE"
    prompt_label.setText("STOPPED")
    instruction_label.setText("Collection stopped")
    countdown_label.setText("Prepare/Capture: --")
    status_label.setText("Status: stopped")
    if session_origin_x_mm is not None and session_origin_y_mm is not None:
        progress_label.setText(
            f"Collected {len(rows)} rows | origin X={session_origin_x_mm:.3f}, Y={session_origin_y_mm:.3f}"
        )
    else:
        progress_label.setText(f"Collected {len(rows)} rows")


def rebaseline():
    global session_state
    session_state = "IDLE"
    reset_live_state(clear_baseline=True)

    prompt_label.setText("WAITING")
    instruction_label.setText("Waiting for first valid sensor sample to set baseline")
    countdown_label.setText("Prepare/Capture: --")
    status_label.setText("Status: baseline reset")
    progress_label.setText("No active collection")
    baseline_label.setText("Baseline: not set")
    origin_label.setText("Session origin: not set")
    samples_label.setText("Samples at point: -")


def go_home():
    global session_state
    session_state = "IDLE"
    move_to_xy(HOME_X_MM, HOME_Y_MM)
    prompt_label.setText(f"{MOVE_CMD} X{HOME_X_MM:.3f} Y{HOME_Y_MM:.3f}")
    instruction_label.setText("Sent home move command")
    countdown_label.setText("Prepare/Capture: --")
    status_label.setText("Status: moving to home")


def query_position():
    send_cnc_cmd("?")
    status_label.setText("Status: sent ? to CNC")


def zero_xyz_here():
    global last_seen_x_mm, last_seen_y_mm, last_seen_z_mm
    global session_origin_x_mm, session_origin_y_mm, session_origin_z_mm

    if not send_cnc_cmd("G92 X0 Y0 Z0"):
        return
    time.sleep(0.1)
    send_cnc_cmd("?")

    last_seen_x_mm = 0.0
    last_seen_y_mm = 0.0
    last_seen_z_mm = 0.0

    if session_state in ("IDLE", "DONE"):
        session_origin_x_mm = 0.0
        session_origin_y_mm = 0.0
        session_origin_z_mm = 0.0

    status_label.setText("Status: zeroed XYZ at current position (G92 X0 Y0 Z0)")
    origin_label.setText("Session origin: XYZ zeroed at current position")
    actual_pos_label.setText("Reported position: X=0.000, Y=0.000, Z=0.000 (just zeroed)")


def poll_sensor_once():
    send_sensor_cmd("C")
    status_label.setText("Status: sent C to sensor")


def session_state_start_capture():
    global session_state, state_start_time, samples_this_point
    session_state = "CAPTURE"
    state_start_time = time.monotonic()
    samples_this_point = 0
    countdown_label.setText(f"Capture: 0/{SAMPLES_PER_POINT}")
    status_label.setText(
        f"Status: capturing at local X={current_local_x_mm:+.3f}, Y={current_local_y_mm:+.3f}"
    )


def update_session_clock():
    global session_state, state_start_time, last_p_request_time

    if session_state not in ("SETTLE", "CONFIRM", "CAPTURE"):
        return

    now = time.monotonic()
    elapsed = now - state_start_time

    if session_state == "SETTLE":
        remaining = max(0.0, SETTLE_SECONDS - elapsed)
        countdown_label.setText(f"Prepare: {remaining:0.2f}s")

        if elapsed >= SETTLE_SECONDS:
            if USE_POSITION_CONFIRM:
                session_state = "CONFIRM"
                state_start_time = now
                last_p_request_time = 0.0
                countdown_label.setText("Confirming position…")
                status_label.setText("Status: awaiting CNC position confirmation")
                send_cnc_cmd("?")
                last_p_request_time = now
            else:
                session_state_start_capture()

    elif session_state == "CONFIRM":
        if elapsed >= POS_CONFIRM_TIMEOUT_SEC:
            status_label.setText(
                f"Status: pos-confirm timeout at local X={current_local_x_mm:+.3f}, "
                f"Y={current_local_y_mm:+.3f} — capturing anyway"
            )
            session_state_start_capture()
        else:
            if last_seen_x_mm is not None and last_seen_y_mm is not None:
                dx = abs(last_seen_x_mm - current_abs_x_mm)
                dy = abs(last_seen_y_mm - current_abs_y_mm)
                if dx <= POS_CONFIRM_TOLERANCE_MM and dy <= POS_CONFIRM_TOLERANCE_MM:
                    status_label.setText(
                        f"Status: position confirmed ({last_seen_x_mm:.2f}, {last_seen_y_mm:.2f})"
                    )
                    session_state_start_capture()
                    return

            if now - last_p_request_time >= POS_P_INTERVAL_SEC:
                send_cnc_cmd("?")
                last_p_request_time = now

            countdown_label.setText(
                f"Confirming… {POS_CONFIRM_TIMEOUT_SEC - elapsed:.1f}s"
            )

    elif session_state == "CAPTURE":
        countdown_label.setText(
            f"Capture: {samples_this_point}/{SAMPLES_PER_POINT} | {elapsed:0.2f}s"
        )
        if elapsed >= CAPTURE_TIMEOUT_SEC:
            status_label.setText("Status: capture timeout, advancing")
            advance_to_next_point()


def request_sensor_periodically():
    global last_c_request_time

    active = (baseline_pa0 is None) or (session_state in ("CAPTURE", "SETTLE", "CONFIRM"))
    if not active:
        return

    now = time.monotonic()
    if now - last_c_request_time >= C_REQUEST_INTERVAL_SEC:
        send_sensor_cmd("C")
        last_c_request_time = now


def append_training_row(raw_pa0, raw_pa5, raw_pa6, delta_pa0, delta_pa5, delta_pa6):
    global samples_this_point

    if session_state != "CAPTURE":
        return
    if current_abs_x_mm is None or current_abs_y_mm is None or session_start_time is None:
        return

    now = time.monotonic()

    point_pa0_samples.append(raw_pa0)
    point_pa5_samples.append(raw_pa5)
    point_pa6_samples.append(raw_pa6)

    row = {
        "session_time_s": now - session_start_time,
        "point_time_s": now - state_start_time,
        "point_index": session_index,
        "repeat": current_repeat,
        "origin_x_mm": session_origin_x_mm,
        "origin_y_mm": session_origin_y_mm,
        "origin_z_mm": session_origin_z_mm,
        "cmd_x_mm": current_local_x_mm,
        "cmd_y_mm": current_local_y_mm,
        "cmd_abs_x_mm": current_abs_x_mm,
        "cmd_abs_y_mm": current_abs_y_mm,
        "raw_pa0": raw_pa0,
        "raw_pa5": raw_pa5,
        "raw_pa6": raw_pa6,
        "delta_pa0": delta_pa0,
        "delta_pa5": delta_pa5,
        "delta_pa6": delta_pa6,
        "smooth_pa0": moving_avg(point_pa0_samples, SMOOTH_N),
        "smooth_pa5": moving_avg(point_pa5_samples, SMOOTH_N),
        "smooth_pa6": moving_avg(point_pa6_samples, SMOOTH_N),
    }
    rows.append(row)

    samples_this_point += 1
    samples_label.setText(f"Samples at point: {samples_this_point}/{SAMPLES_PER_POINT}")

    if samples_this_point >= SAMPLES_PER_POINT:
        advance_to_next_point()


def refresh_live_plot():
    point_count = len(y_pa0)
    if point_count == 0:
        curve_pa0.setData([], [])
        curve_pa5.setData([], [])
        curve_pa6.setData([], [])
        plot.setXRange(0, MAX_POINTS - 1, padding=0)
        return

    x_start = max(0, sample_counter - point_count)
    x_vals = list(range(x_start, sample_counter))

    curve_pa0.setData(x_vals, list(y_pa0))
    curve_pa5.setData(x_vals, list(y_pa5))
    curve_pa6.setData(x_vals, list(y_pa6))

    window_start = max(0, sample_counter - MAX_POINTS)
    window_end = max(MAX_POINTS - 1, sample_counter - 1)
    xmin, xmax = plot.getViewBox().viewRange()[0]
    if abs(xmin - window_start) > 0.5 or abs(xmax - window_end) > 0.5:
        plot.setXRange(window_start, window_end, padding=0)


